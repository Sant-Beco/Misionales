# ============================================
# MISONALES - .gitignore
# ============================================

# ===== ARCHIVOS SENSIBLES =====
.env
*.db
*.sqlite
*.sqlite3
*.sql

# ===== PYTHON =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
ENV/
env/
*.egg-info/
dist/
build/

# ===== DATOS GENERADOS =====
data/generated_pdfs/**/*.pdf
data/firmas/**/*.png

# Mantener estructura de carpetas
!data/generated_pdfs/.gitkeep
!data/firmas/.gitkeep

# ===== BACKUPS =====
*_OLD.py
*_OLD.html
*_BACKUP.*
backup_*/

# ===== IDEs =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== SISTEMA OPERATIVO =====
.DS_Store
Thumbs.db
desktop.ini

# ===== TESTS =====
.pytest_cache/
.coverage
htmlcov/
*.cover

# ===== TEMPORALES =====
*.tmp
*.temp
*.log 

# Python compiled
*.pyc
*.pyo